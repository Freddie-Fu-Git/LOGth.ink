---
import '~/styles/global.css'
import '~/styles/markdown.css'
import '~/styles/lqip.css'
import '~/styles/github-card.css'
import { SITE } from '~/config'
import Head from '~/components/base/Head.astro'
import Header from './Header.astro'
import Footer from './Footer.astro'
import { getLangFromUrl } from '~/i18n/utils'

type Props = {
  title: string
  description: string
  image?: string
}

const { title, description, image }: Props = Astro.props
const lang = getLangFromUrl(Astro.url)
const pageTitle = title.trim().length > 0 ? `${title} | ${SITE.title}` : SITE.title
---

<!doctype html>
<html {lang} transition:name="root" transition:animate={SITE.transition ? 'fade' : 'none'}>
  <head>
    <Head title={pageTitle} {description} {image} />
  </head>
  <body class="flex flex-col">
    <Header />
    <div class="grow flex">
      <main class="relative border-x border-border/50 global-layout-width mx-auto grow min-w-0">
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>
