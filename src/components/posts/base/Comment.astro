---
import { COMMENT_CONFIG } from '~/config'
import Gitalk from './Gitalk.astro'
import Artalk from './Artalk.astro'
import { getLangFromUrl, useTranslations } from '~/i18n/utils'

interface Props {
  id: string
  title: string
}

const { id, title } = Astro.props
const { enabled, system } = COMMENT_CONFIG

if (!enabled || system === 'none') {
  return null
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<div class="comment-container">
  <h3 class="text-xl font-semibold mb-6 text-[var(--color-heading)]">{t('post.comments')}</h3>

  {system === 'gitalk' && <Gitalk id={id} title={title} />}
  {system === 'artalk' && <Artalk id={id} title={title} />}
</div>
